<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taskmanager.controller.FormController"
      spacing="10"
      alignment="CENTER"
      prefWidth="400"
      prefHeight="350">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Nova Tarefa"/>

    <TextField fx:id="txtTitulo"
               promptText="Título"/>

    <TextArea fx:id="txtDescricao"
              promptText="Descrição"
              prefHeight="100"/>

    <ComboBox fx:id="cbPrioridade"/>

    <CheckBox fx:id="chkConcluida"
              text="Concluída"/>

    <Label fx:id="lblErro"
           style="-fx-text-fill: red;"/>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnSalvar"
                text="Salvar"
                onAction="#salvar"/>

        <Button fx:id="btnCancelar"
                text="Cancelar"
                onAction="#cancelar"/>
    </HBox>

</VBox>
